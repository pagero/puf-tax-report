<?xml version="1.0" encoding="UTF-8"?>
<TaxReport xmlns="urn:pagero:PageroUniversalFormat:TaxReport:1.0" xmlns:xs="http://www.w3.org/2001/XMLSchema"
    xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
    xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

    <!--
        EXAMPLE: Payment received in France (Flux 10, sub-streams 10.2 and 10.4)
        Documenting received payments for:
        - B2B invoices (sub-stream 10.2) - two invoice payments with different VAT breakdowns
        - B2C receipt transactions / POS (sub-stream 10.4) - aggregated daily payment
        
        Currency must always be EUR for French payment reporting.
        Each Payment element represents one payment event on a specific paid date.
    -->

    <!-- Specification Identifier -->
    <cbc:CustomizationID>urn:pagero.com:puf:taxreport:1.0</cbc:CustomizationID>
    <!-- Business process type identifier -->
    <cbc:ProfileID>urn:pagero.com:puf:taxreport:1.0</cbc:ProfileID>
    <!-- TT-1: Tax report identifier (issuer assigned) -->
    <cbc:ID>PAY-2026-001</cbc:ID>
    <!-- TT-3: Tax report issue date -->
    <cbc:IssueDate>2026-02-05</cbc:IssueDate>
    <!-- Classification Identifier: INCOME for sales payment reporting -->
    <ClassificationIdentifier>INCOME</ClassificationIdentifier>
    <!-- TT-89/TT-90: Report period for the payment reporting -->
    <ReportPeriod>
        <cbc:StartDate>2026-01-01</cbc:StartDate>
        <cbc:EndDate>2026-01-31</cbc:EndDate>
    </ReportPeriod>
    <!-- TT-13: Issuer (declaring) party of the report -->
    <cac:IssuerParty>
        <cac:PartyLegalEntity>
            <!-- Issuer registration name -->
            <cbc:RegistrationName>Dupont et Fils SAS</cbc:RegistrationName>
            <!-- TT-13: Reporting party (Seller) legal registration identifier (SIREN) -->
            <cbc:CompanyID schemeID="0002">412280737</cbc:CompanyID>
        </cac:PartyLegalEntity>
    </cac:IssuerParty>

    <!-- ============================================================ -->
    <!-- PAYMENT 1: Received payment of a B2B invoice (sub-stream 10.2)
         Invoice with mixed VAT rates (20% standard + 5.5% reduced) -->
    <!-- ============================================================ -->
    <Payment>
        <!-- TT-94: Document currency (must be EUR for France) -->
        <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>
        <ReferencedDocument>
            <!-- PaymentDataType: INVOICE for B2B invoice payment reporting (sub-stream 10.2) -->
            <PaymentDataType>INVOICE</PaymentDataType>
            <!-- TT-91: Invoice identifier of the referenced document -->
            <cbc:ID>FAC-2025-00842</cbc:ID>
            <!-- TT-102: Issue date of the referenced/paid invoice -->
            <cbc:IssueDate>2025-12-15</cbc:IssueDate>
        </ReferencedDocument>
        <!-- TT-92: Date when payment was received -->
        <cbc:PaidDate>2026-01-10</cbc:PaidDate>
        <!-- Payment totals broken down by tax rate -->
        <PaymentTotal>
            <!-- TT-93/TT-95: Amount received at 20% standard VAT rate -->
            <PaymentSubtotal>
                <cbc:TaxInclusiveAmount currencyID="EUR">1200.00</cbc:TaxInclusiveAmount>
                <cbc:Percent>20</cbc:Percent>
            </PaymentSubtotal>
            <!-- TT-93/TT-95: Amount received at 5.5% reduced VAT rate -->
            <PaymentSubtotal>
                <cbc:TaxInclusiveAmount currencyID="EUR">316.50</cbc:TaxInclusiveAmount>
                <cbc:Percent>5.5</cbc:Percent>
            </PaymentSubtotal>
        </PaymentTotal>
    </Payment>

    <!-- ============================================================ -->
    <!-- PAYMENT 2: Received payment of another B2B invoice (sub-stream 10.2)
         Invoice with single VAT rate, fully exempt (intra-community) -->
    <!-- ============================================================ -->
    <Payment>
        <!-- TT-94: Document currency -->
        <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>
        <ReferencedDocument>
            <!-- PaymentDataType: INVOICE for B2B invoice payment -->
            <PaymentDataType>INVOICE</PaymentDataType>
            <!-- TT-91: Invoice identifier -->
            <cbc:ID>FAC-2025-00901</cbc:ID>
            <!-- TT-102: Invoice issue date -->
            <cbc:IssueDate>2025-12-20</cbc:IssueDate>
        </ReferencedDocument>
        <!-- TT-92: Payment received date -->
        <cbc:PaidDate>2026-01-15</cbc:PaidDate>
        <PaymentTotal>
            <!-- TT-93/TT-95: Amount received at 0% (exempt) -->
            <PaymentSubtotal>
                <cbc:TaxInclusiveAmount currencyID="EUR">5000.00</cbc:TaxInclusiveAmount>
                <cbc:Percent>0</cbc:Percent>
            </PaymentSubtotal>
        </PaymentTotal>
    </Payment>

    <!-- ============================================================ -->
    <!-- PAYMENT 3: Received payment for B2C receipt transactions / POS (sub-stream 10.4)
         Aggregated daily cash sales. No invoice reference needed.
         Each Payment element represents one day's collected payments. -->
    <!-- ============================================================ -->
    <Payment>
        <!-- TT-98: Document currency -->
        <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>
        <ReferencedDocument>
            <!-- PaymentDataType: RECEIPTTRANSACTION for B2C/POS payment reporting (sub-stream 10.4) -->
            <PaymentDataType>RECEIPTTRANSACTION</PaymentDataType>
        </ReferencedDocument>
        <!-- TT-96: Payment date (the day these transactions were paid) -->
        <cbc:PaidDate>2026-01-08</cbc:PaidDate>
        <PaymentTotal>
            <!-- TT-97/TT-99: Amount collected at 20% standard rate -->
            <PaymentSubtotal>
                <cbc:TaxInclusiveAmount currencyID="EUR">840.00</cbc:TaxInclusiveAmount>
                <cbc:Percent>20</cbc:Percent>
            </PaymentSubtotal>
            <!-- TT-97/TT-99: Amount collected at 10% intermediate rate -->
            <PaymentSubtotal>
                <cbc:TaxInclusiveAmount currencyID="EUR">275.00</cbc:TaxInclusiveAmount>
                <cbc:Percent>10</cbc:Percent>
            </PaymentSubtotal>
            <!-- TT-97/TT-99: Amount collected at 5.5% reduced rate -->
            <PaymentSubtotal>
                <cbc:TaxInclusiveAmount currencyID="EUR">158.25</cbc:TaxInclusiveAmount>
                <cbc:Percent>5.5</cbc:Percent>
            </PaymentSubtotal>
        </PaymentTotal>
    </Payment>
</TaxReport>
