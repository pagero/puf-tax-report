<?xml version="1.0" encoding="UTF-8"?>
<TaxReport xmlns="urn:pagero:PageroUniversalFormat:TaxReport:1.0" xmlns:xs="http://www.w3.org/2001/XMLSchema"
    xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
    xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

    <!--
        EXAMPLE: Payment made on purchase invoices (EXPENSE - France, Flux 10 sub-stream 10.2)

        Use case: A French company reports payments made to suppliers for cross-border purchase invoices.
        ClassificationIdentifier = EXPENSE indicates outgoing payment (purchase side).
        
        This shows:
        - Payment on a B2B purchase invoice from a German supplier (intra-community, 0% VAT)
        - Payment on a B2B purchase invoice from a domestic French supplier (20% standard VAT)
    -->

    <cbc:CustomizationID>urn:pagero.com:puf:taxreport:1.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:pagero.com:puf:taxreport:1.0</cbc:ProfileID>
    <!-- TT-1: Tax report identifier -->
    <cbc:ID>PAY-EXP-2026-001</cbc:ID>
    <!-- TT-3: Tax report issue date -->
    <cbc:IssueDate>2026-02-05</cbc:IssueDate>
    <!-- Classification Identifier: EXPENSE for purchase payment reporting -->
    <ClassificationIdentifier>EXPENSE</ClassificationIdentifier>
    <!-- Report type: NEW (initial submission) -->
    <Type>NEW</Type>
    <!-- TT-89/TT-90: Report period -->
    <ReportPeriod>
        <cbc:StartDate>2026-01-01</cbc:StartDate>
        <cbc:EndDate>2026-01-31</cbc:EndDate>
    </ReportPeriod>
    <!-- TT-13: Issuer/declaring party (the buyer making payments) -->
    <cac:IssuerParty>
        <cac:PartyLegalEntity>
            <cbc:RegistrationName>Martin Distribution SARL</cbc:RegistrationName>
            <cbc:CompanyID schemeID="0002">523847291</cbc:CompanyID>
        </cac:PartyLegalEntity>
    </cac:IssuerParty>

    <!-- ============================================================ -->
    <!-- PAYMENT 1: Payment made on intra-community purchase invoice 
         (German supplier, reverse charge / exempt VAT) -->
    <!-- ============================================================ -->
    <Payment>
        <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>
        <ReferencedDocument>
            <PaymentDataType>INVOICE</PaymentDataType>
            <!-- TT-91: Supplier's invoice number -->
            <cbc:ID>DE-INV-2025-4721</cbc:ID>
            <!-- TT-102: Invoice issue date -->
            <cbc:IssueDate>2025-12-01</cbc:IssueDate>
        </ReferencedDocument>
        <!-- TT-92: Date payment was made -->
        <cbc:PaidDate>2026-01-05</cbc:PaidDate>
        <PaymentTotal>
            <!-- TT-93/TT-95: Full amount paid at 0% (intra-community reverse charge) -->
            <PaymentSubtotal>
                <cbc:TaxInclusiveAmount currencyID="EUR">8500.00</cbc:TaxInclusiveAmount>
                <cbc:Percent>0</cbc:Percent>
            </PaymentSubtotal>
        </PaymentTotal>
    </Payment>

    <!-- ============================================================ -->
    <!-- PAYMENT 2: Payment made on domestic French purchase invoice
         (French supplier, standard 20% VAT) -->
    <!-- ============================================================ -->
    <Payment>
        <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>
        <ReferencedDocument>
            <PaymentDataType>INVOICE</PaymentDataType>
            <!-- TT-91: Supplier's invoice number -->
            <cbc:ID>FAC-2025-FR-1089</cbc:ID>
            <!-- TT-102: Invoice issue date -->
            <cbc:IssueDate>2025-12-18</cbc:IssueDate>
        </ReferencedDocument>
        <!-- TT-92: Date payment was made -->
        <cbc:PaidDate>2026-01-20</cbc:PaidDate>
        <PaymentTotal>
            <!-- TT-93/TT-95: Amount paid at 20% standard rate -->
            <PaymentSubtotal>
                <cbc:TaxInclusiveAmount currencyID="EUR">3600.00</cbc:TaxInclusiveAmount>
                <cbc:Percent>20</cbc:Percent>
            </PaymentSubtotal>
        </PaymentTotal>
    </Payment>
</TaxReport>
